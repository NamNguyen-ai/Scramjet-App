# Comma-separated list of SOCKS5 sidecars used for egress IP rotation.
# Leave blank (or unset) to disable rotation and egress from the host IP.
#
# Examples:
#   WIREPROXY_SOCKS=                                  # disabled
#   WIREPROXY_SOCKS=wireproxy1:25344                  # single peer
#   WIREPROXY_SOCKS=wireproxy1:25344,wireproxy2:25344 # round-robin pool
#
# ./start.sh writes this file for you based on the menu selection.
WIREPROXY_SOCKS=

# Override the Scramjet HTTP port (default 8080). Only this port is published
# from the docker-compose stack -- the wireproxy SOCKS5 ports stay on the
# internal "scramjet-egress" docker network.
# PORT=8080
